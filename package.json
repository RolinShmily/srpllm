{
  "name": "srpllm",
  "type": "module",
  "version": "1.2.9",
  "packageManager": "pnpm@10.17.1",
  "description": "SrP-LLM 中转站客户端一键配置工具：安装 Claude Code / Codex 并引导填写 base_url、api_token 与模型",
  "author": {
    "name": "RolinShmily",
    "url": "https://github.com/RolinShmily"
  },
  "license": "MIT",
  "homepage": "https://github.com/RolinShmily/srpllm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RolinShmily/srpllm.git"
  },
  "bugs": "https://github.com/RolinShmily/srpllm/issues",
  "keywords": [
    "srpllm",
    "litellm",
    "relay",
    "claude-code",
    "codex",
    "cli",
    "config",
    "proxy"
  ],
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "bin": {
    "srpllm": "bin/srpllm.mjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "dev": "tsx ./src/cli.ts",
    "build": "unbuild",
    "start": "node bin/srpllm.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "dependencies": {
    "ansis": "^4.1.0",
    "cac": "^6.7.14",
    "inquirer": "^12.9.6",
    "ora": "^9.0.0",
    "pathe": "^2.0.3",
    "tinyexec": "^1.0.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.4.1",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^22.18.6",
    "eslint": "^9.36.0",
    "eslint-plugin-format": "^1.0.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "unbuild": "^3.6.1"
  }
}
